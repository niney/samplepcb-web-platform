# samplepcb 정적 페이지 짧은 URL — /spec → /spcb/pages/spec.php
# spcb/pages/ 에 같은 이름의 .php 가 실제로 있을 때만 리라이트하므로
# 그누보드 코어 경로(bbs·shop·adm 등)·실제 파일과 충돌하지 않는다.
# ※ 신규 파일(코어 비수정). nginx 예약 경로(/app·/api)는 앞단에서 이미 분기됨.
#   전제: vhost AllowOverride All + mod_rewrite 활성.

RewriteEngine On

# 1) 이미 존재하는 파일/디렉터리는 그대로 서빙(리라이트 안 함)
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# 2) 최상위 한 단계 슬러그(소문자·숫자·하이픈)이고 spcb/pages/{슬러그}.php 가 있으면 내부 리라이트
RewriteCond %{DOCUMENT_ROOT}/spcb/pages/$1.php -f
RewriteRule ^([a-z0-9-]+)/?$ /spcb/pages/$1.php [L,QSA]
