# supplier-search-engine 공급사 API 자격증명 (백엔드 전용 — 브라우저로 전달 금지)
# 실제 값은 .env 에 넣고 커밋하지 않는다(.gitignore 등록됨).

# Mouser
MOUSER_API_KEY=
MOUSER_BASE_URL=https://api.mouser.com

# DigiKey (OAuth2 client_credentials)
DIGIKEY_CLIENT_ID=
DIGIKEY_CLIENT_SECRET=
DIGIKEY_ACCOUNT_ID=
DIGIKEY_BASE_URL=https://api.digikey.com
DIGIKEY_TOKEN_URL=https://api.digikey.com/v1/oauth2/token

# UniKeyIC
UNIKEYIC_API_KEY=
UNIKEYIC_BASE_URL=

# 공급사 동시 호출 수
SEARCH_SUPPLIER_CONCURRENCY=4
