{
  "name": "samplepcb-web-mono-app",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "turbo dev",
    "dev:web": "turbo dev --filter=web",
    "dev:rnd": "turbo dev --filter=rnd",
    "dev:api": "turbo dev --filter=api",
    "build": "turbo build",
    "typecheck": "turbo typecheck",
    "lint": "turbo lint",
    "test": "turbo test",
    "format": "prettier --write \"**/*.{ts,vue,js,json,md}\"",
    "clean": "turbo clean && rimraf node_modules"
  },
  "devDependencies": {
    "turbo": "2.9.18",
    "typescript": "^6.0.3",
    "prettier": "^3.4.2",
    "rimraf": "^6.0.1"
  }
}
