# 레거시 → 신규 DB 마이그레이션 전용 env (실행: pnpm migrate:* — tsx --env-file=.env.migration)
# ⚠ 리허설과 컷오버는 이 파일의 타깃 URL 만 바꿔서 구분한다(원장 ledger-<타깃DB>.json 도 자동 분리).

# ── 소스: 레거시 그누보드/영카트 DB(읽기 전용 — legacySelect 가 SELECT 만 허용) ──
# 증분 동기화(pnpm migrate:sync)는 운영 직결이 정석(docs/LEGACY_DB_MIGRATION.md §6-D):
#   비밀번호 특수문자는 URL 인코딩(! → %21, @ → %40, # → %23). JDBC 파라미터(useSSL 등)는 불필요.
#LEGACY_DATABASE_URL="mysql://hyoh9150:<비밀번호URL인코딩>@www.samplepcb.co.kr:3306/hyoh9150"
# 로컬 폴백: 운영 풀 덤프 임포트본(samplepcb_legacy_full) · 구형 2020-12 덤프: samplepcb_legacy
LEGACY_DATABASE_URL="mysql://root@127.0.0.1:3306/samplepcb_legacy_full"

# ── 타깃: 신규 플랫폼 공유 DB — 두 URL 은 반드시 같은 DB(run.ts 가 검증) ──
# 리허설은 사본 DB(예: samplepcb_mig)로! 컷오버 때만 실 DB(samplepcb).
G5_DATABASE_URL="mysql://user:pass@127.0.0.1:3306/samplepcb_mig"
DATABASE_URL="mysql://user:pass@127.0.0.1:3306/samplepcb_mig"

# ── 실파일 소스(선택 — 미설정 시 해당 단계 생략+리포트) ──
# 게시판 첨부·에디터·회원 이미지 원본(레거시 data/ 미러)
MIGRATE_LEGACY_DATA_DIR="D:/work/workspace_other/samplepcb_php/data"
# 거버 원본(운영 /gerber_files/ 미러 — rsync 등으로 받아둔 로컬 경로)
#MIGRATE_LEGACY_FILES_DIR="D:/backup/gerber_files"
# 게시판 첨부 복사 타깃(기본: <플랫폼 루트>/samplepcb-web/data)
#MIGRATE_TARGET_DATA_DIR="D:/work/workspace_other/samplepcb-web-platform/samplepcb-web/data"

# ── 파일서버(거버 업로드 — upload-files.ts) ──
# 리허설은 demo, 컷오버는 gerber 권장(file.samplepcb.kr serviceType)
FILE_SERVICE_TYPE=demo
#FILE_SERVER_URL=https://file.samplepcb.kr
