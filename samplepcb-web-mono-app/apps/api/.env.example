PORT=3333
# 바인딩 주소(선택). 미설정 시 127.0.0.1 = 로컬 전용(권장, nginx가 같은 호스트에서 프록시).
# 컨테이너 등 외부 바인딩이 필요할 때만 0.0.0.0
HOST=127.0.0.1
JWT_SECRET=change-me-must-match-gnuboard-extend-secret
DATABASE_URL="mysql://user:pass@localhost:3306/samplepcb" # 그누보드와 공유 DB — prisma migrate reset 절대 금지(g5_* 드랍됨)
# 레거시 그누보드/영카트 DB — 마이그레이션/검증 스크립트 전용, 읽기 전용 (src/lib/legacy-db.ts)
LEGACY_DATABASE_URL="mysql://user:pass@127.0.0.1:3306/<그누보드DB>"
# 로컬 그누보드/영카트 DB — 담기 API 의 g5_shop_cart INSERT + 템플릿 상품 SELECT (한정 예외, src/lib/g5-db.ts)
G5_DATABASE_URL="mysql://user:pass@localhost:3306/<그누보드DB>"
# 메인 슬라이드 이미지 저장 경로 — sp-php data 디렉토리 절대경로(그누보드 G5_DATA_PATH).
# sp-node 가 banner/{bn_id} 로 배너 이미지를 쓰고 sp-php 브릿지가 서빙(디스크 공유, Windows/Linux 경로차).
G5_DATA_PATH="/path/to/samplepcb-web/data"
# PHP 알림 브리지(sp-php) 베이스 URL — 관리자 주문 상태 전이(입금/배송)의 메일/SMS 를 그누보드
# 커스텀 메일 템플릿 재사용으로 발송(POST {URL}/spcb/api/order-notify). 로컬 XAMPP Apache 포트.
# 서비스 JWT(svc:'sp-node', HS256)는 위 JWT_SECRET 으로 서명 → spcb/lib/secret.php 와 동일 값 필수.
SPCB_BRIDGE_URL="http://127.0.0.1:8888"
# ── 견적 메일 발송 (sp-node nodemailer 직송, src/lib/mailer.ts) ──
# 로컬은 127.0.0.1:25 = Mailpit 가 가로채 외부 0통(docs/LOCAL_MAIL_TESTING.md). 운영은 실제 릴레이 지정.
SMTP_HOST=127.0.0.1
SMTP_PORT=25
# 인증형 릴레이가 필요할 때만(로컬 Mailpit 은 무인증). 둘 다 채워야 auth 사용.
#SMTP_USER=
#SMTP_PASS=
# 발신 주소 fallback — 미설정 시 g5_shop_default 담당자 이메일(발신처)을 쓴다.
#MAIL_FROM="sales@samplepcb.co.kr"
# ── 견적 알림톡 발송 (카카오, iwinv, src/lib/alimtalk.ts) ──
# 로컬 기본 비활성 = 실발송 0(fail-safe). 실발송하려면 'true' + 아래 토큰 필수(운영만).
ALIMTALK_ENABLED=false
ALIMTALK_URL="https://alimtalk.bizservice.iwinv.kr/api/v2/send/"
# iwinv AUTH 헤더 값(레거시 하드코딩 토큰을 여기로 이관). ENABLED=true 일 때만 필요.
#ALIMTALK_AUTH_TOKEN=""
# ── pcb-projects (거버 담기 API) ──
# 응답 redirectUrl 기준 도메인 (기본 https://local-web.samplepcb.co.kr)
#WEB_BASE_URL=https://local-web.samplepcb.co.kr
# 파일서버 (기본 https://file.samplepcb.kr). serviceType 은 운영 gerber / 테스트 demo
#FILE_SERVER_URL=https://file.samplepcb.kr
#FILE_SERVICE_TYPE=gerber
# ── AI(Ollama) 연동 — 시스템 구성도 생성 등 (src/lib/ai, docs/AI_DIAGRAM.md) ──
# 값이 있으면 관리자 화면(AI 연동 탭) 저장값보다 **우선** 적용된다(파일 관리 권장 — 키를 DB에 안 남김).
# 미설정 시: 관리자 저장값 → 기본값(http://127.0.0.1:11434, 로컬 데몬은 키 불요) 순.
# ollama.com 직결: AI_BASE_URL=https://ollama.com + API 키(ollama.com 계정 설정에서 발급) 필수.
#AI_BASE_URL=https://ollama.com
# 이미지·PDF 미리보기 첨부가 있을 때 사용할 비전 모델(미설정 시 qwen3.5:cloud).
#AI_ATTACHMENT_VISION_MODEL=qwen3.5:cloud
#AI_API_KEY=

# ── Elasticsearch (부품 카탈로그 검색, sp-parts 인덱스) ──
# 로컬은 xpse 와 공유하는 단일 노드. 기존 인덱스(pcbparts 등)는 건드리지 않음(sp- prefix 만).
# ES 다운이어도 앱은 뜸 — 검색만 503, 색인은 큐 적재 후 기동 시 드레인.
#ES_NODE_URL=http://127.0.0.1:9200

# ── sp-engine(BOM 추출 + 공급사 검색, Python) 프록시 ──
# /api/admin/bom/* 이 이 엔진으로 프록시된다. 엔진은 사설망·무인증(인증은 sp-node 담당).
# 미설정 시 로컬 기본값 사용.
#BOM_ENGINE_URL=http://127.0.0.1:8400
#BOM_ENGINE_TIMEOUT_MS=120000
