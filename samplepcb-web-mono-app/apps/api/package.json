{
  "name": "api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/server.ts",
    "build": "tsup src/server.ts --format esm --clean",
    "start": "node --env-file=.env dist/server.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "rnd:probe": "tsx --env-file=.env src/scripts/probe-rnd-file-classifier.ts",
    "rnd:request-probe": "tsx --env-file=.env src/scripts/probe-rnd-pcb-request-document.ts",
    "db:generate": "prisma generate",
    "legacy:sample": "tsx --env-file=.env src/scripts/extract-legacy-gerber-samples.ts",
    "migrate:gate": "tsx --env-file=.env.migration src/scripts/migrate/run.ts --phase=gate",
    "migrate:dry": "tsx --env-file=.env.migration src/scripts/migrate/run.ts --dry-run",
    "migrate:run": "tsx --env-file=.env.migration src/scripts/migrate/run.ts",
    "migrate:files": "tsx --env-file=.env.migration src/scripts/migrate/upload-files.ts",
    "migrate:sync": "tsx --env-file=.env.migration src/scripts/migrate/sync.ts",
    "migrate:verify": "tsx --env-file=.env.migration src/scripts/migrate/verify.ts",
    "migrate:wipe": "tsx --env-file=.env.migration src/scripts/migrate/wipe-test-data.ts",
    "pricing:sync": "tsx src/scripts/sync-pricing-data.ts",
    "pricing:capture": "tsx src/scripts/capture-legacy-pricing-goldens.ts",
    "market:seed": "tsx --env-file=.env src/scripts/seed-market-house-expert.ts",
    "market:seed-anchor": "tsx --env-file=.env src/scripts/seed-market-anchor-item.ts",
    "db:migrate": "prisma migrate dev",
    "clean": "rimraf dist .turbo"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/jwt": "^9.0.1",
    "@fastify/multipart": "^10.0.0",
    "@fastify/sensible": "^6.0.2",
    "@prisma/client": "^6.0.0",
    "@sp/api-contract": "workspace:*",
    "@sp/utils": "workspace:*",
    "exceljs": "^4.4.0",
    "fastify": "^5.2.0",
    "fastify-plugin": "^5.0.1",
    "fastify-type-provider-zod": "^4.0.0",
    "fflate": "^0.8.2",
    "mysql2": "^3.22.5",
    "nodemailer": "^9.0.3",
    "pdf-parse": "^2.4.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@sp/config": "workspace:*",
    "@types/node": "^22.10.0",
    "@types/nodemailer": "^8.0.1",
    "eslint": "^10.0.1",
    "prisma": "^6.0.0",
    "rimraf": "^6.0.1",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^6.0.3",
    "vitest": "^3.0.0"
  }
}
