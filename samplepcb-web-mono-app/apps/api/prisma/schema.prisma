// sp-node 소유 테이블(sp_ 접두) 스키마 — 그누보드와 **같은 DB(samplepcb)를 공유**한다
// (2026-07-03 통합: 백업 정합성·조인 단순화. DB 공유 ≠ 스키마 결합 — 소유권 규칙 유지).
// 그누보드 g5_* 는 Node 가 소유/수정하지 않는다 — 단 g5_shop_cart/옵션 행은
// 담기 API 의 한정 예외(HANDOFF 결정 로그 #6)로 Prisma 가 아닌 mysql2 로 수행.
//
// ⚠⚠ 공유 DB 이므로 `prisma migrate reset` **절대 금지** — 대상 DB 의 모든 테이블
// (그누보드 g5_* 포함)을 드랍한다.
// ⚠ `prisma migrate dev` 도 쓰지 말 것 — 이 DB 에선 g5_* 60개를 drift 로 감지해
// **항상 전체 reset 을 요구**한다(2026-07-04 실측, HANDOFF 결정 로그). 스키마 변경 절차:
// migrations/ 에 추가 전용(ALTER ADD·CREATE 만) migration.sql 수기 작성 → 눈 검수 →
// `prisma migrate deploy`(drift 감지·shadow DB 없음) → `prisma generate`.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// 견적 스냅샷 — 담기 시 가격 재검증의 단일 진실원본.
// quoteId 는 DB 저장 방식(서명 토큰 기각 — rfq 기록·감사·일괄 무효화 필요, HANDOFF 결정).
model SpQuote {
  id            String   @id @default(uuid()) // = quoteId
  category      String // 제품군: standard|metalMask|advance|flexible…
  orderCategory String // sample|mass
  qty           Int
  specJson      Json // 계산 입력 스냅샷
  specHash      String // 담기 시 변조 대조용 (spec 정규화 JSON 의 sha256)
  autoPrice     Int? // null = 자동견적 불가(rfq)
  eta           String? // 계산 시점 도착예정일 (표시용)
  priceVersion  String // 가격표 버전 (일괄 무효화용)
  expiresAt     DateTime // 발급 +72h
  createdAt     DateTime @default(now())

  @@map("sp_quote")
}

// 주문의 실체(= PCB 프로젝트). 영카트 상품/카트에는 스냅샷만 가고 사양은 여기 산다.
// cart 와의 관계(담김/주문됨)는 저장하지 않고 ct_id 조인으로 파생(HANDOFF 3장).
model SpOrderSpec {
  id            BigInt    @id @default(autoincrement()) // = projectId
  // mb_id 는 레거시가 이메일 아이디를 쓰며 255 로 확폭 운영 — sp 측은 utf8mb4 인덱스 한도(191) 채택 (2026-07-07)
  mbId          String?   @db.VarChar(191) // 비회원 null (목록 미노출)
  quoteId       String // sp_quote 연결
  ctId          Int? // g5_shop_cart 연결 (파생 조회 키)
  projectName   String
  category      String
  orderCategory String
  qty           Int
  message       String?   @db.MediumText // 레거시 it_basic 최대 ~1MB 실측 — TEXT(64KB) 절단 방지 (2026-07-07)
  companyName   String?   @db.VarChar(255) // 수신처 회사명 스냅샷(견적서 문서에 박제, 2층 구조의 문서층)
  specJson      Json
  status        String    @default("active") // active|deleted|archived
  quoteStatus   String // priced|rfq|quoted
  finalPrice    Int? // 관리자 확정가 (quoted)
  pricedBy      String?   @db.VarChar(191) // mb_id 계열(이메일 아이디 수용) — 2026-07-07 확폭
  pricedAt      DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([mbId, status])
  @@index([quoteId])
  @@index([ctId]) // 레거시 이관·ct_id 조인(테마 뱃지/썸네일) 조회용 (2026-07-07)
  @@map("sp_order_spec")
}

// 파일 연결(폴리모픽) — 기존 운영 sp_file 스키마 준수(uploaded_by 는 varchar(20) 확정).
// 실파일은 file.samplepcb.kr 파일서버, 여기엔 pathToken 만.
model SpFile {
  id             BigInt   @id @default(autoincrement())
  refType        String   @map("ref_type") @db.VarChar(50) // 'sp_order_spec'
  refId          BigInt   @map("ref_id")
  uploadFileName String   @map("upload_file_name") @db.VarChar(255)
  originFileName String   @map("origin_file_name") @db.VarChar(255)
  pathToken      String   @map("path_token") @db.VarChar(500)
  size           BigInt   @default(0)
  writeDate      DateTime @map("write_date")
  fileType       String?  @map("file_type") @db.VarChar(50) // gerber|thumbnail|bom|drawing
  uploadedBy     String?  @map("uploaded_by") @db.VarChar(20) // ADMIN|PARTNER|…

  @@index([refType, refId], map: "idx_sp_file_ref")
  @@map("sp_file")
}

// 회원별 견적 기본값(2층 구조의 프로필층) — 관리자가 회사명을 저장하면 기억해
// 같은 회원의 다음 견적서에 프리필한다. 그누보드 여분필드(mb_1/mb_2)를 쓰지 않기
// 위한 sp측 명시 필드(2026-07-04 결정). 사용자측 신청 폼 수집은 다음 단계.
//
// 2026-07-07 레거시 마이그레이션 확장: 레거시 g5_member 여분/커스텀 필드를 명시 컬럼으로
// 승격(라벨 정본 = 계약 AdminMemberBusiness · 레거시 theme/samplepcb/member_info.php).
// mb_1→memberType(정규화) · mb_2→companyName · mb_3→bizNo · mb_4→ceoName · mb_5→bizType(업태)
// · mb_6→bizItem(종목) · mb_7→managerName · mb_8→taxEmail · mb_9→managerPhone · mb_10~12→
// bizZip/bizAddr1/bizAddr2 · mb_13→partnerKind · mb_15→managerEmail · mb_partner_auth→partnerAuth.
// 정규화 전 원본(mb_1 raw)·저사용 잔여 커스텀(mb_14/16~20 JSON, 계좌 6컬럼 등)은 legacyJson 보존.
model SpMemberProfile {
  mbId         String   @id @db.VarChar(191) // mb_id 계열(이메일 아이디 수용) — 2026-07-07 확폭
  companyName  String?  @db.VarChar(255)
  memberType   String?  @db.VarChar(20) // personal|corporate|partner (mb_1 정규화)
  bizNo        String?  @db.VarChar(50) // 사업자등록번호
  ceoName      String?  @db.VarChar(255) // 대표자
  bizType      String?  @db.VarChar(255) // 업태
  bizItem      String?  @db.VarChar(255) // 종목
  managerName  String?  @db.VarChar(255) // 담당자명
  taxEmail     String?  @db.VarChar(255) // 세금계산서 이메일
  managerPhone String?  @db.VarChar(50) // 담당자 전화
  managerEmail String?  @db.VarChar(255) // 담당자 이메일 (레거시 mb_15)
  bizZip       String?  @db.VarChar(100) // 사업장 우편번호(레거시 오염: 주소 문자열 실재 최대 35자 — 보존 확폭)
  bizAddr1     String?  @db.VarChar(255) // 사업장 주소
  bizAddr2     String?  @db.VarChar(255) // 사업장 상세주소
  partnerKind  String?  @db.VarChar(100) // 파트너 종류 (레거시 mb_13)
  partnerAuth  Int      @default(0) // 파트너 인증 등급 0=미인증/1=A/2=B/3=C/4=부품판매
  legacyJson   Json? // 잔여 레거시 커스텀 원본 보존(mb_1 raw·mb_14/16~20·계좌 등)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("sp_member_profile")
}

// 주문별 세금계산서 발행 정보 — 레거시 g5_shop_order od_1~od_11(주문서 "세금계산서" 섹션,
// 무통장 한정 입력) 이관처. 신규 주문 경로의 수집 폼 연결은 후속 과제(계획 문서 참조).
// od_12~17 은 레거시에서도 미사용 확정이라 승격하지 않는다.
model SpOrderBizInfo {
  odId        String   @id @db.VarChar(30) // g5_shop_order.od_id (FK 아님 — 공유 DB 조인 키)
  companyName String?  @db.VarChar(255) // od_1 회사명
  bizNo       String?  @db.VarChar(50) // od_2 사업자등록번호
  ceoName     String?  @db.VarChar(255) // od_3 대표자 성명
  bizType     String?  @db.VarChar(255) // od_4 업태
  bizItem     String?  @db.VarChar(255) // od_5 종목
  managerName String?  @db.VarChar(255) // od_6 담당자명
  taxEmail    String?  @db.VarChar(255) // od_7 세금계산서 이메일
  companyTel  String?  @db.VarChar(50) // od_8 회사전화
  bizZip      String?  @db.VarChar(20) // od_9 사업장 우편번호
  bizAddr1    String?  @db.VarChar(255) // od_10 사업장 기본주소
  bizAddr2    String?  @db.VarChar(255) // od_11 사업장 상세주소
  createdAt   DateTime @default(now())

  @@map("sp_order_biz_info")
}

// 상품 별점후기 — 레거시 영카트 g5_shop_item_use(상품 사용후기=별점평가) 이관처.
// 레거시는 후기를 "거버 제출건별 상품(it_id)"에 붙였으나, 신규는 상품이 4종 템플릿뿐이라
// 후기를 주문/프로젝트(sp_order_spec) 단위로 재귀속한다: it_id → 레거시 cart 라인(od,ct) →
// quoteId=uuidV5("od:ct") → sp_order_spec.quoteId (05-reviews.ts, 2026-07-09).
// - is_password(회원 비번 해시 사본)는 어떤 형태로도 저장하지 않는다(보안).
// - _legacy 혼합 저장 금지 — legacyJson 분리(SpMemberProfile 관례, 직렬화 500 전례 회피).
model SpReview {
  id           BigInt    @id @default(autoincrement())
  legacyIsId   Int?      @unique // 레거시 is_id — 증분 sync 멱등 upsert 키(신규 후기는 null)
  mbId         String    @db.VarChar(191) // 작성자(=주문자). 필수 저장
  quoteId      String? // sp_order_spec.quoteId 귀속(매핑 실패 시 null — 데이터 보존)
  specId       BigInt? // sp_order_spec.id 부가 캐시(정본은 quoteId)
  score        Int // is_score 1~5
  subject      String?   @db.VarChar(255) // is_subject
  content      String    @db.Text // is_content
  isConfirm    Int       @default(0) // is_confirm 노출 승인 게이트(증분에서 0 가능)
  replySubject String?   @db.VarChar(255) // is_reply_subject(관리자 답변)
  replyContent String?   @db.Text // is_reply_content
  replyName    String?   @db.VarChar(50) // is_reply_name(관리자 mb_nick)
  repliedAt    DateTime? // 레거시 답변시각 컬럼 부재 → 이관분 항상 null
  writeDate    DateTime // is_time
  legacyItId   String?   @db.VarChar(20) // 원본 it_id(매핑 실패 조사·감사)
  legacyJson   Json? // is_ip 등 잔여 원본(is_password 는 절대 제외)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([quoteId])
  @@index([mbId])
  @@map("sp_review")
}

// ── PCB 재능마켓 (sp_market_*, 2026-07-08 1차=매칭까지) ─────────────────────
// 회원 = 그누보드(g5_member). mbId 는 JWT 클레임 유래 문자열 — FK 금지(공유 DB 조인 키).
// 분야/CAD 등 코드 사전은 @sp/api-contract 의 MARKET_* 상수가 정본, 여기엔 코드만 저장.
// 상태값은 String + 앱단 리터럴 유니온(asXxx 내로잉) — 기존 sp_* 관례(enum 미사용).
// 첨부·증빙 파일은 sp_file 폴리모픽 재사용(refType='sp_market_project'|'sp_market_expert').

// 전문가 프로필 — 회원당 1행(mbId unique). 관리자 승인 워크플로 포함.
// expertType: individual(개인·지정3번)|company(기업·지정2번)|house(당사·지정1번, 시드 1행).
// status: pending|approved|rejected|suspended.
model SpMarketExpert {
  id               BigInt    @id @default(autoincrement())
  mbId             String    @unique @db.VarChar(191) // mb_id 계열(이메일 아이디 수용)
  expertType       String    @db.VarChar(20)
  displayName      String    @db.VarChar(100) // 이름(개인)/상호(기업) — 공개 프로필 비마스킹
  phone            String    @db.VarChar(50)
  identityVerified Boolean   @default(false) // 1차: 관리자 심사 화면 수동 체크(실인증 연동 2차)
  careerRange      String    @db.VarChar(20) // 경력 구간 코드
  contactHours     String?   @db.VarChar(100) // 통화 가능시간(자유 입력)
  region           String?   @db.VarChar(20) // 활동 지역 코드
  travelRange      String?   @db.VarChar(20) // 이동 가능 거리 코드
  intro            String?   @db.Text
  serviceAreas     Json // 제공 가능한 개발 영역 코드 배열
  categories       Json // 회로개발 세부분야 코드 배열
  cadTools         Json // CAD 툴 코드 배열
  bankName         String?   @db.VarChar(50) // 정산계좌(2차 정산 대비 수집) — 본인·관리자 외 비노출
  bankHolder       String?   @db.VarChar(50)
  bankAccount      String?   @db.VarChar(50)
  termsAgreedAt    DateTime // 약관 + 프로필 공개 동의 시각
  status           String    @default("pending") @db.VarChar(20)
  statusReason     String?   @db.VarChar(255) // 반려/정지 사유
  decidedBy        String?   @db.VarChar(191) // 처리 관리자 mbId
  decidedAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([status]) // 관리자 심사 탭
  @@map("sp_market_expert")
}

// 프로젝트 의뢰 — method: open(역견적=공개 블라인드 입찰)|targeted(지정견적=1:1).
// status: bidding|closed|awarded|cancelled (2차 예약: working|completed).
// 마감은 cron 없는 lazy 파생 — bidDeadlineAt vs now 비교(읽기 응답·쓰기 가드 동일 식).
model SpMarketProject {
  id                       BigInt    @id @default(autoincrement())
  mbId                     String    @db.VarChar(191) // 의뢰인 — 공개 응답엔 maskName 값만 나간다
  title                    String    @db.VarChar(200)
  requestType              String    @map("category") @db.VarChar(30) // system|individual
  serviceAreas             Json // 실제 필요한 개발 영역 코드 배열(복수)
  // 물리명 specialties — 인접 물리 컬럼 category(=requestType)와 category/categories 혼동 회피.
  categories               Json      @map("specialties") // 세부분야 코드 배열(회로·펌웨어 STEP2)
  cadTools                 Json // 요구 툴 코드 배열(ECAD·MCAD·디자인 통합) — 빈 배열=무관, 'any' 는 레거시
  description              String    @db.Text
  // AI 생성 시스템 구성도(단일 HTML) — 공개 범위는 description 과 동일(설명에서 파생).
  // 렌더는 반드시 sandbox iframe(srcdoc) — LLM 출력이라 DOM 직결 금지.
  diagramHtml              String?   @db.MediumText
  // 구성 명세 JSON(DiagramSpec 직렬화) — 구성도의 원천 데이터. 재생성과 후속 문서
  // (ROC·포스팅 요약) 파생의 근원이라 HTML 과 별도로 보존한다.
  diagramSpec              String?   @db.MediumText
  // AI 작업검토지시서 마크다운(Phase 2) — 공개 범위는 description 과 동일.
  rocMd                    String?   @db.MediumText
  // 인터뷰 답변 원본([{code,answer}]) — 응답 미노출 저장 전용, 명세·문서 재생성의 근원.
  interviewAnswers         Json?
  // 신규 등록에서 원본 답변의 견적 가능 전문가 공개를 명시 동의한 시각. null인 기존 건은
  // 어떤 신규 응답에도 답변을 싣지 않아 과거 비공개 정책을 소급 변경하지 않는다.
  interviewAnswersSharedAt DateTime?
  // 분야별 포스팅 카드(Phase 3, MarketPostingCards) — 공개 범위는 description 과 동일.
  postings                 Json?
  // AI 잡 출처와 결정적 렌더 출처의 검증 메타데이터. 모델·프롬프트/입력/출력 해시·jobId를
  // 보존하며, 실제 산출물과 해시가 다르면 응답 라벨을 고객 수정본으로 내린다.
  aiGenerationMeta         Json?
  ndaRequired              Boolean   @default(true) // 프로젝트 단위 NDA 게이트(첨부 일괄)
  budgetRange              String    @db.VarChar(20) // 예산 구간 코드(금액 아님)
  startHopeDate            String?   @db.VarChar(10) // 'YYYY-MM-DD' 표시용 KST 날짜 문자열(타임존 경계 회피)
  dueHopeDate              String?   @db.VarChar(10)
  bidDeadlineAt            DateTime // 견적 마감 절대 시각(서버 계산: 3/7/14일 프리셋 or 지정일 23:59:59 KST)
  method                   String    @db.VarChar(20)
  targetExpertId           BigInt? // 지정견적 대상(sp_market_expert.id) — open 이면 null
  status                   String    @default("bidding") @db.VarChar(20)
  awardedBidId             BigInt? // 채택 입찰 — 2차 계약(sp_market_contract)의 연결 근원
  awardedAt                DateTime?
  viewCount                Int       @default(0) // 원자 +1(소유자/관리자 제외), dedup 없음(1차)
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  @@index([status, bidDeadlineAt]) // 공개 목록(입찰중 WHERE + lazy 마감 + 마감순 정렬)
  @@index([mbId]) // 내 의뢰 목록
  @@index([targetExpertId]) // 지정견적 인박스(전문가별)
  @@map("sp_market_project")
}

// 입찰(견적 제출) — 블라인드: 소유자·관리자만 전체, 전문가는 자기 것만, 공개는 개수만.
// status: submitted|awarded|rejected|withdrawn. 재제출=같은 행 수정(unique 유지).
model SpMarketBid {
  id           BigInt   @id @default(autoincrement())
  projectId    BigInt
  expertId     BigInt // sp_market_expert.id
  mbId         String   @db.VarChar(191) // 전문가 mbId 복제 — 소유 판정·내 입찰을 무조인으로
  amount       Int // 원 단위 KRW(프로토타입의 만원 단위를 정규화)
  durationDays Int
  warranty     String?  @db.VarChar(255) // 하자보수 문구
  message      String   @db.Text // 제안 메시지
  status       String   @default("submitted") @db.VarChar(20)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt // 재제출 최종 시각

  @@unique([projectId, expertId]) // 전문가당 1입찰(중복 제출 레이스의 최종 방어선)
  @@index([projectId, status]) // 비교 목록·채택 일괄 전이·bidCount 집계
  @@index([mbId]) // 내 입찰 목록
  @@map("sp_market_bid")
}

// NDA 전자서명 — 프로젝트 단위 1인 1서명(재서명 요청은 멱등). 문구 원문은 계약
// (MARKET_NDA_TEXT)이 버전 관리하고 여기엔 textVersion 만 저장.
model SpMarketNdaSign {
  id          BigInt   @id @default(autoincrement())
  projectId   BigInt
  mbId        String   @db.VarChar(191) // 서명자(승인 전문가)
  textVersion String   @db.VarChar(20)
  signedName  String   @db.VarChar(100) // 서명 시 입력 성명(회원 탈퇴 후 감사 대비 스냅샷)
  ip          String   @db.VarChar(45) // IPv6 수용
  createdAt   DateTime @default(now())

  @@unique([projectId, mbId]) // 중복 방지 + 서명 여부 판정 키
  @@map("sp_market_nda_sign")
}

// 마켓 설정 싱글턴(id=1) — g5_shop_default 는 영카트 소유라 마켓 설정을 섞지 않는다.
// 행 부재 시 GET 은 기본값 폴백, PATCH 가 upsert(id=1) — 시드 불요.
model SpMarketSettings {
  id        Int      @id @default(1)
  feeRateBp Int      @default(1000) // 전문가측 수수료율 basis point(1000=10.00%)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("sp_market_settings")
}

// 계약(2차: 결제·검수·정산) — 채택(award) tx 에서 프로젝트당 1건 생성(projectId unique,
// unaward 없음 모델). fee/payout 은 채택 시점 스냅샷. status: pending|paid|delivered|
// completed|settled|cancelled. paid 승격은 cron 없는 lazy write-back(od·카트 라인 대조).
// 산출물 파일은 sp_file 재사용(refType='sp_market_contract', fileType='deliverable').
model SpMarketContract {
  id              BigInt    @id @default(autoincrement())
  projectId       BigInt    @unique // 프로젝트당 1계약(unaward 없음 모델)
  bidId           BigInt // 채택 입찰(sp_market_bid.id)
  clientMbId      String    @db.VarChar(191) // 의뢰인 — 복제(무조인 소유 판정)
  expertMbId      String    @db.VarChar(191) // 채택 전문가 — 복제(무조인 소유 판정)
  expertId        BigInt // sp_market_expert.id
  amount          Int // 입찰액 = VAT 포함 총액(수수료도 총액 기준)
  feeRateBp       Int // 수수료율 bp — 채택 시점 스냅샷
  feeAmount       Int // round(amount×bp/10000) — 채택 시점 스냅샷
  payoutAmount    Int // amount − feeAmount — 채택 시점 스냅샷
  contractKey     String    @unique @db.VarChar(36) // uuid v4 = 영카트 io_id·주문 라인 식별자
  ctId            Int? // g5_shop_cart.ct_id — checkout 주입/재주입 시 갱신
  status          String    @default("pending") @db.VarChar(20) // pending|paid|delivered|completed|settled|cancelled
  paidAt          DateTime?
  paidOdId        String?   @db.VarChar(20) // 승격 근거 주문(g5_shop_order.od_id)
  deliveredAt     DateTime?
  deliveryNote    String?   @db.Text // 납품 보고 노트(재보고 시 갱신)
  completedAt     DateTime?
  confirmedBy     String?   @db.VarChar(10) // client|auto
  holdAt          DateTime? // 관리자 자동확정 정지 시각(있으면 auto 승격 정지)
  holdReason      String?   @db.VarChar(500)
  settledAt       DateTime?
  settledBy       String?   @db.VarChar(191) // 정산 처리 관리자 mbId
  settleNote      String?   @db.VarChar(500)
  cancelledAt     DateTime?
  cancelReason    String?   @db.VarChar(500)
  // 입찰 채택 시점의 의뢰 조건·AI 산출물·공개 동의 답변·채택 견적 전체 스냅샷.
  // 원 프로젝트가 유지되더라도 분쟁 감사 기준을 계약 행에 고정한다.
  requestSnapshot Json?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([status]) // 관리자 계약 목록 탭 + delivered 자동확정 스윕
  @@index([clientMbId]) // 내 의뢰 계약
  @@index([expertMbId]) // 내 작업 계약
  @@map("sp_market_contract")
}

// ── SEO 메타 (sp_seo, 2026-07-10 P1) ───────────────────────────────────────
// 영카트/그누보드 코어엔 페이지별 SEO 가 없다(cf_title 전역 접미사 + cf_add_meta 전역
// raw 1벌뿐). 관리=sp-vue(/app/admin/seo)→sp-node→여기, 소비=sp-php 테마 head.sub.php 가
// 페이지 전역변수(스크립트 basename + $it/$bo_table) 매칭으로 1쿼리 직접 SELECT(read-only).
// 정본: docs/SEO_MANAGEMENT.md. 폴백: 엔티티 오버라이드 → scope 기본 → global 기본 → 코어 cf_title.
// og:title/이미지·Product JSON-LD 는 $it 에서 자동 유도가 기본이고 이 레코드는 오버라이드용.
// canonical 은 저장 아닌 계산(G5_DOMAIN='' 호스트 무관 설계) — 여기 값은 수동 오버라이드만.
model SpSeo {
  id              BigInt   @id @default(autoincrement())
  scope           String   @db.VarChar(20) // global|item|board|page
  refKey          String   @default("") @db.VarChar(191) // global='' · item=it_id · board=bo_table · page=basename/경로
  metaTitle       String?  @db.VarChar(255) // <title> 오버라이드(빈값이면 자동/코어 title)
  metaDescription String?  @db.VarChar(500) // meta description
  ogImage         String?  @db.VarChar(500) // OG 이미지(상대경로 저장 가능 — 소비측이 절대 URL 화)
  canonical       String?  @db.VarChar(500) // 수동 오버라이드만(기본은 host+path 계산)
  robots          String?  @db.VarChar(50) // 예: noindex,nofollow (null=기본 index,follow)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([scope, refKey]) // (scope,ref)당 1레코드 — upsert 키
  @@map("sp_seo")
}

// sp-node 범용 설정(key-value 싱글턴 스토어) — 코어 g5_config/g5_shop_default 를 건드리지
// 않는 sp 소유 설정. gerber_price_mode · ai_base_url · ai_api_key(관리자 외 원문 비노출).
model SpConfig {
  key       String   @id @db.VarChar(100)
  value     String   @db.Text
  updatedAt DateTime @updatedAt

  @@map("sp_config")
}

// AI 유스케이스 설정 — 연결(sp_config ai_*)과 분리된 유스케이스 단위(활성·모델·프롬프트).
// 행은 서버가 레지스트리(lib/ai/usecases.ts) 기준으로 lazy 생성. 현재 market.request-diagram 1종.
model SpAiUsecase {
  useCase        String   @id @db.VarChar(100)
  enabled        Boolean  @default(false)
  model          String   @db.VarChar(100)
  promptTemplate String   @db.Text
  updatedAt      DateTime @updatedAt

  @@map("sp_ai_usecase")
}

// ── 부품 카탈로그 (BOM 공급사 검색 자동 인제스트, docs/PARTS_SEARCH.md) ──────
// DB=진실원본, ES(sp-parts)=재구축 가능한 검색 파생물. 카탈로그는 사실 데이터이며
// BOM 매칭 상태(VERIFIED 등 문맥)는 저장하지 않는다.

// 정규 부품 1행 — 공급사 무관. upsert 키 = (mpnNorm, manufacturerNorm).
model SpPart {
  id               BigInt        @id @default(autoincrement())
  mpn              String        @db.VarChar(191) // 원문 MPN(표시용)
  mpnNorm          String        @db.VarChar(191) // 대문자·영숫자만(@sp/utils normalizeMpn)
  manufacturerName String        @db.VarChar(191) // 별칭 해소 후 정준 표시명
  manufacturerNorm String        @db.VarChar(191) // 소문자·영숫자만
  description      String?       @db.Text
  category         String?       @db.VarChar(191)
  packageCode      String?       @db.VarChar(32) // 임페리얼 정준(0402) 또는 원문 대문자
  lifecycle        String?       @db.VarChar(64)
  datasheetUrl     String?       @db.VarChar(500)
  imageUrl         String?       @db.VarChar(500) // 공급사 제품 사진 직링크(정본 — 신뢰순 대표 1개)
  specsJson        Json // 공급사 normalized_specs 병합(표시용 — dielectric·온도범위 포함)
  specsSi          Json // SI 정준 수치만(resistanceOhm 등 SPEC_SI_FIELD 키) — ES 색인 원천
  specConflicts    Json? // 공급사 간 스펙 실충돌 기록 {field:[{value,suppliers,fetchedAt}]} — null=충돌 없음
  firstSeenAt      DateTime      @default(now())
  lastSeenAt       DateTime      @default(now())
  indexedAt        DateTime? // 마지막 ES 색인 성공 시각(null=미색인)
  factsFingerprint String?       @db.Char(64) // 전체 실공급사 오퍼+정본 정책 fingerprint
  indexFingerprint String?       @db.Char(64) // 마지막 성공 ES 문서+색인 정책 fingerprint
  offers           SpPartOffer[]

  @@unique([mpnNorm, manufacturerNorm])
  @@index([lastSeenAt])
  @@map("sp_part")
}

// 공급사별 판매 정보 — 공급사 추가는 supplier 값 추가일 뿐(스키마 무변경).
model SpPartOffer {
  id                 BigInt             @id @default(autoincrement())
  partId             BigInt
  supplier           String             @db.VarChar(32) // mouser|digikey|unikeyic|…
  supplierSku        String             @default("") @db.VarChar(191) // null 공급사는 '' 로 정규화(unique 안정)
  productUrl         String?            @db.VarChar(1000)
  stock              Int?
  moq                Int?
  orderMultiple      Int?
  packaging          String?            @db.VarChar(64)
  currency           String?            @db.VarChar(8) // 대표 통화(프라이스브레이크 첫 행)
  leadTime           String?            @db.VarChar(64)
  rawJson            Json // 공급사 원본 product payload — 감사·재처리용
  fetchedAt          DateTime
  contentFingerprint String?            @db.Char(64) // fetchedAt 제외 저장 내용+인제스트 정책 fingerprint
  part               SpPart             @relation(fields: [partId], references: [id], onDelete: Cascade)
  priceBreaks        SpPartPriceBreak[]

  @@unique([partId, supplier, supplierSku])
  @@index([supplier])
  @@map("sp_part_offer")
}

// 수량 구간 단가 — fetch 단위 replace-all.
model SpPartPriceBreak {
  id       BigInt      @id @default(autoincrement())
  offerId  BigInt
  qty      Int
  price    Decimal     @db.Decimal(14, 6)
  currency String      @default("") @db.VarChar(8)
  offer    SpPartOffer @relation(fields: [offerId], references: [id], onDelete: Cascade)

  @@unique([offerId, qty])
  @@map("sp_part_price_break")
}

// ES 색인 실패 재시도 큐 — DB 쓰기는 성공했으나 색인이 실패한 부품. 기동 시·주기 drain.
model SpPartIndexQueue {
  id       BigInt   @id @default(autoincrement())
  partId   BigInt
  reason   String   @db.VarChar(191)
  attempts Int      @default(0)
  queuedAt DateTime @default(now())

  @@index([partId])
  @@map("sp_part_index_queue")
}

// 동일 공급사 결과의 중복 인제스트를 서버 재시작·다중 인스턴스에서도 한 번으로 수렴시키는 원장.
// fingerprint에는 실제 카탈로그 입력과 정책 버전이 들어가며, 원본 BOM 파일 해시는 사용하지 않는다.
model SpPartIngestRun {
  id                 BigInt                   @id @default(autoincrement())
  fingerprint        String                   @unique @db.Char(64)
  policyVersion      String                   @db.VarChar(64)
  sourceJobId        String?                  @db.VarChar(64)
  status             String                   @default("queued") @db.VarChar(16) // queued|running|completed|failed
  leaseUntil         DateTime?
  stats              Json?
  timing             Json?
  error              String?                  @db.VarChar(500)
  createdAt          DateTime                 @default(now())
  startedAt          DateTime?
  completedAt        DateTime?
  updatedAt          DateTime                 @updatedAt
  supplierSearchRuns SpBomSupplierSearchRun[]

  @@index([status, createdAt])
  @@map("sp_part_ingest_run")
}

// 고객 스마트 BOM 견적 — 업로드→파싱→매칭→검토→견적요청(RFQ). 설계: docs/BOM_QUOTE.md.
// xpse 의 sp_bom_document/sp_estimate_document(별도 DB)와 무관한 sp-node 소유 신규 모델.
// 금액 필드는 "예상 스냅샷"(sp_config 기본값·서버 재계산) — 확정은 confirmed* 로 분리.
model SpBomQuote {
  id                        BigInt                     @id @default(autoincrement())
  mbId                      String                     @db.VarChar(60)
  title                     String                     @db.VarChar(191)
  status                    String                     @default("draft") @db.VarChar(16) // draft|requested|reviewing|answered|closed|canceled
  fileName                  String?                    @db.VarChar(255)
  contentHash               String?                    @db.VarChar(64) // 원본 SHA-256 — 동일 파일 안내용
  engineJobId               String?                    @db.VarChar(64) // 엔진 인메모리 잡 — 재시작 시 소멸(재업로드)
  activeAnalysisRunId       BigInt?                    @unique @map("active_analysis_run_id")
  activeSupplierSearchRunId BigInt?                    @unique @map("active_supplier_search_run_id")
  buildStatus               String                     @default("ready") @db.VarChar(12) // parsing|selecting|building|ready|failed
  setQty                    Int                        @default(1)
  spareQty                  Int                        @default(0)
  itemsTotal                Int                        @default(0) // KRW 정수(반올림)
  shippingFee               Int                        @default(0)
  managementFee             Int                        @default(0)
  finalTotal                Int                        @default(0)
  usdKrwRateUsed            Decimal?                   @db.Decimal(10, 2)
  exchangeRateSnapshot      Json? // 적용 환율의 출처·기준일·안전계수(RFQ 감사 스냅샷)
  uncostedCount             Int                        @default(0)
  customerMemo              String?                    @db.Text
  adminMemo                 String?                    @db.Text // 내부 메모 — 고객 응답 미노출
  answerNote                String?                    @db.Text // 고객 노출 회신
  confirmedShippingFee      Int?
  confirmedManagementFee    Int?
  confirmedTotal            Int?
  enrichStatus              String                     @default("idle") @db.VarChar(12) // idle|searching|done|failed — 자동 보강 생명주기(단일 진실)
  enrichedAt                DateTime? // 마지막 보강 반영(재매칭 저장) 시각
  requestedAt               DateTime?
  answeredAt                DateTime?
  createdAt                 DateTime                   @default(now())
  updatedAt                 DateTime                   @updatedAt
  items                     SpBomQuoteItem[]
  sheets                    SpBomQuoteSheet[]
  candidates                SpBomQuoteCandidate[]
  selectionEvents           SpBomQuoteSelectionEvent[]
  analysisRuns              SpBomAnalysisRun[]         @relation("BomQuoteAnalysisRuns")
  activeAnalysisRun         SpBomAnalysisRun?          @relation("BomQuoteActiveAnalysis", fields: [activeAnalysisRunId], references: [id], onDelete: SetNull)
  supplierSearchRuns        SpBomSupplierSearchRun[]   @relation("BomQuoteSupplierSearchRuns")
  activeSupplierSearchRun   SpBomSupplierSearchRun?    @relation("BomQuoteActiveSupplierSearch", fields: [activeSupplierSearchRunId], references: [id], onDelete: SetNull)

  @@index([mbId, status])
  @@index([status, requestedAt])
  @@map("sp_bom_quote")
}

// BOM 추출 실행 — sp-engine은 계산 서비스이며, 완료 결과의 영속 단일 진실은 sp-node가 소유한다.
// 실행은 append-only이고 quote.activeAnalysisRunId만 성공한 최신 실행으로 원자 전환한다.
model SpBomAnalysisRun {
  id                 BigInt                   @id @default(autoincrement())
  quoteId            BigInt
  engineJobId        String?                  @db.VarChar(64)
  engine             String                   @db.VarChar(32)
  schemaVersion      String                   @db.VarChar(32)
  parserVersion      String                   @db.VarChar(191)
  sourceFile         String                   @db.VarChar(255)
  engineModel        String?                  @db.VarChar(191)
  promptVersion      String?                  @db.VarChar(191)
  status             String                   @db.VarChar(16) // completed|failed
  summary            Json
  headers            Json
  failures           Json
  createdAt          DateTime                 @default(now())
  completedAt        DateTime?
  quote              SpBomQuote               @relation("BomQuoteAnalysisRuns", fields: [quoteId], references: [id], onDelete: Cascade)
  activeForQuote     SpBomQuote?              @relation("BomQuoteActiveAnalysis")
  sheets             SpBomAnalysisSheet[]
  components         SpBomAnalysisComponent[]
  supplierSearchRuns SpBomSupplierSearchRun[]

  @@index([quoteId, createdAt])
  @@map("sp_bom_analysis_run")
}

// 공급사 검색 실행 — 영속 분석 입력에서 만든 독립 계산 잡의 수명·옵션·오류를 추적한다.
// engineJobId가 소멸해도 같은 analysisRun으로 새 실행을 만들 수 있다.
model SpBomSupplierSearchRun {
  id                 BigInt           @id @default(autoincrement())
  quoteId            BigInt
  analysisRunId      BigInt
  engineJobId        String?          @db.VarChar(64)
  status             String           @db.VarChar(16) // preparing|running|completed|failed
  options            Json
  preflight          Json?
  resultSummary      Json?            @map("result_summary") // 실제 호출·캐시·시간·한도 소진 행의 compact 운영 지표
  catalogIngestRunId BigInt?
  error              String?          @db.VarChar(500)
  createdAt          DateTime         @default(now())
  startedAt          DateTime?
  completedAt        DateTime?
  quote              SpBomQuote       @relation("BomQuoteSupplierSearchRuns", fields: [quoteId], references: [id], onDelete: Cascade)
  activeForQuote     SpBomQuote?      @relation("BomQuoteActiveSupplierSearch")
  analysisRun        SpBomAnalysisRun @relation(fields: [analysisRunId], references: [id], onDelete: Cascade)
  catalogIngestRun   SpPartIngestRun? @relation(fields: [catalogIngestRunId], references: [id], onDelete: SetNull)
  resultArtifact     SpBomSupplierResultArtifact?
  searchTraces       SpBomSupplierSearchTrace[]

  @@index([quoteId, createdAt])
  @@index([analysisRunId, createdAt])
  @@index([catalogIngestRunId])
  @@index([status, createdAt])
  @@map("sp_bom_supplier_search_run")
}

// 공급사 검색 완료 원본을 압축 보존하는 영속 작업 원장. sp-engine 인메모리 잡이 사라져도
// DB·ES 저장과 견적 partId 연결을 동일 payload로 재개한다.
model SpBomSupplierResultArtifact {
  id                  BigInt                 @id @default(autoincrement())
  supplierSearchRunId BigInt                 @unique @map("supplier_search_run_id")
  payload             Bytes                  @db.LongBlob
  payloadChecksum     String                 @map("payload_checksum") @db.Char(64)
  payloadBytes        Int                    @map("payload_bytes")
  status              String                 @default("queued") @db.VarChar(16) // queued|running|completed|failed|dead
  attempts            Int                    @default(0)
  nextAttemptAt       DateTime?              @map("next_attempt_at")
  leaseUntil          DateTime?              @map("lease_until")
  lastErrorCode       String?                @map("last_error_code") @db.VarChar(64)
  lastError           String?                @map("last_error") @db.VarChar(500)
  completedAt         DateTime?              @map("completed_at")
  createdAt           DateTime               @default(now()) @map("created_at")
  updatedAt           DateTime               @updatedAt @map("updated_at")
  supplierSearchRun   SpBomSupplierSearchRun @relation(fields: [supplierSearchRunId], references: [id], onDelete: Cascade)

  @@index([status, nextAttemptAt])
  @@map("sp_bom_supplier_result_artifact")
}

// 엔진이 실행 순간 확정한 실제 검색어·공급사 내부 fallback provenance.
// 검색 실행별 컴포넌트에 한 번만 저장하고 BOM 목록의 반복 폴링에서는 지연 조회한다.
model SpBomSupplierSearchTrace {
  id                  BigInt                 @id @default(autoincrement())
  supplierSearchRunId BigInt                 @map("supplier_search_run_id")
  engineComponentId   String                 @map("engine_component_id") @db.VarChar(24)
  rowIdx               Int                    @map("row_idx")
  traceVersion         String                 @map("trace_version") @db.VarChar(64)
  primaryQuery         String                 @map("primary_query") @db.VarChar(500)
  fallbackQuery        String?                @map("fallback_query") @db.VarChar(500)
  fallbackUsed         Boolean                @map("fallback_used")
  attemptCount         Int                    @map("attempt_count")
  payload              Json
  createdAt            DateTime               @default(now()) @map("created_at")
  supplierSearchRun    SpBomSupplierSearchRun @relation(fields: [supplierSearchRunId], references: [id], onDelete: Cascade, map: "fk_bom_supplier_trace_run")

  @@unique([supplierSearchRunId, engineComponentId], map: "uq_bom_supplier_trace_run_component")
  @@index([supplierSearchRunId, rowIdx], map: "idx_bom_supplier_trace_run_row")
  @@map("sp_bom_supplier_search_trace")
}

// 회원별 공급사 검색 일일 사용량 — 인메모리 카운터 대신 재시작·다중 인스턴스에도 유지한다.
model SpBomSupplierDailyUsage {
  id          BigInt   @id @default(autoincrement())
  mbId        String   @db.VarChar(60)
  dayKey      String   @db.Char(10) // Asia/Seoul YYYY-MM-DD
  searchCount Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([mbId, dayKey])
  @@index([dayKey, searchCount])
  @@map("sp_bom_supplier_daily_usage")
}

// 분석 시트 원본 스냅샷 — 선택 여부는 견적 영역(sp_bom_quote_sheet)에 남기고 분석 자체는 불변이다.
model SpBomAnalysisSheet {
  id             BigInt                   @id @default(autoincrement())
  analysisRunId  BigInt
  sheetIndex     Int
  sheetName      String                   @db.VarChar(191)
  status         String                   @db.VarChar(16) // parsed|not_bom|error
  componentCount Int                      @default(0)
  columnCount    Int                      @default(0)
  failureReason  String?                  @db.VarChar(500)
  payload        Json
  createdAt      DateTime                 @default(now())
  analysisRun    SpBomAnalysisRun         @relation(fields: [analysisRunId], references: [id], onDelete: Cascade)
  components     SpBomAnalysisComponent[]

  @@unique([analysisRunId, sheetIndex])
  @@index([analysisRunId, status])
  @@map("sp_bom_analysis_sheet")
}

// 엔진 ComponentRecord 원본 JSON을 payload에 그대로 박제한다. 자주 조인·표시하는 안정 필드만
// 열로 승격하며, 엔진이 새 필드를 추가해도 Node 표시 계층이 따라오기 전에 데이터부터 보존된다.
model SpBomAnalysisComponent {
  id                   BigInt             @id @default(autoincrement())
  analysisRunId        BigInt
  analysisSheetId      BigInt
  engineComponentId    String             @db.VarChar(24)
  sourceRows           Json
  referenceDesignators Json
  partNumber           String?            @db.VarChar(191)
  manufacturer         String?            @db.VarChar(191)
  componentType        String?            @db.VarChar(64)
  description          String?            @db.VarChar(1000)
  quantity             Int?
  packageCode          String?            @db.VarChar(191)
  reviewStatus         String             @db.VarChar(16)
  confidence           Float?
  searchText           String?            @db.Text
  payload              Json
  createdAt            DateTime           @default(now())
  analysisRun          SpBomAnalysisRun   @relation(fields: [analysisRunId], references: [id], onDelete: Cascade)
  analysisSheet        SpBomAnalysisSheet @relation(fields: [analysisSheetId], references: [id], onDelete: Cascade)
  quoteItems           SpBomQuoteItem[]

  @@unique([analysisRunId, engineComponentId])
  @@index([analysisSheetId, id])
  @@index([analysisRunId, reviewStatus])
  @@map("sp_bom_analysis_component")
}

// 업로드 워크북 시트 분석·선택 스냅샷 — 선택 시트만 견적 계산·공급사 검색에 사용.
model SpBomQuoteSheet {
  id             BigInt     @id @default(autoincrement())
  quoteId        BigInt
  sheetIndex     Int
  sheetName      String     @db.VarChar(191)
  status         String     @db.VarChar(16) // parsed|not_bom|error
  componentCount Int        @default(0)
  selected       Boolean    @default(false)
  failureReason  String?    @db.VarChar(500)
  warnings       Json?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  quote          SpBomQuote @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@unique([quoteId, sheetIndex])
  @@index([quoteId, selected])
  @@map("sp_bom_quote_sheet")
}

// 견적 라인 — orderQty·selectedOffer 스냅샷이 단일 진실(요청 후 재선정 없음).
// partId 는 카탈로그(sp_part) 느슨한 참조(FK 없음 — 카탈로그 정리와 독립).
model SpBomQuoteItem {
  id                      BigInt                     @id @default(autoincrement())
  quoteId                 BigInt
  analysisComponentId     BigInt?                    @map("analysis_component_id")
  rowIdx                  Int
  included                Boolean                    @default(true)
  mpn                     String                     @db.VarChar(191)
  manufacturerName        String?                    @db.VarChar(191)
  description             String?                    @db.VarChar(1000)
  bomQty                  Int
  orderQty                Int                        @default(0)
  matchStatus             String                     @default("none") @db.VarChar(8) // auto|manual|none
  matchEvidence           Json? // 엔진 component 판정·후보·자동 선정 정책 스냅샷(BOM 문맥)
  recommendedCandidateKey String?                    @db.VarChar(64) // 하이브리드 정책의 최초/현재 자동추천
  selectedCandidateKey    String?                    @db.VarChar(64) // 고객이 실제 선택한 견적 후보(카탈로그 직접선택은 null)
  selectionSource         String                     @default("none") @db.VarChar(16) // none|auto|customer|catalog|admin|legacy
  partId                  BigInt?
  selectedOffer           Json?
  lineTotalKrw            Decimal?                   @db.Decimal(14, 2)
  sourceRow               Json?
  sourceSheetIndex        Int?
  sourceSheetName         String?                    @db.VarChar(191)
  createdAt               DateTime                   @default(now())
  updatedAt               DateTime                   @updatedAt
  quote                   SpBomQuote                 @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  analysisComponent       SpBomAnalysisComponent?    @relation(fields: [analysisComponentId], references: [id], onDelete: SetNull)
  candidates              SpBomQuoteCandidate[]
  selectionEvents         SpBomQuoteSelectionEvent[]

  @@unique([quoteId, rowIdx])
  @@index([quoteId, sourceSheetIndex])
  @@index([analysisComponentId])
  @@map("sp_bom_quote_item")
}

// 공급사 엔진 후보의 견적 문맥 스냅샷. 엔진 잡은 재시작 시 소멸하므로 고객 후보 비교가
// 인메모리 결과에 의존하지 않게 quoteId+rowIdx에 박제한다. payload는 엔진 스키마 변화를
// 흡수하고, 목록/정렬에 필요한 안정 필드만 열로 승격한다.
model SpBomQuoteCandidate {
  id               BigInt         @id @default(autoincrement())
  quoteId          BigInt
  quoteItemId      BigInt         @map("quote_item_id")
  candidateKey     String         @db.VarChar(64)
  technicalRank    Int
  status           String         @db.VarChar(32)
  selectionMode    String         @db.VarChar(24) // exact|variant|spec-compatible|review
  safety           String         @db.VarChar(12) // safe|caution|blocked
  autoEligible     Boolean        @default(false)
  mpn              String         @db.VarChar(191)
  manufacturerName String?        @db.VarChar(191)
  payload          Json
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  quote            SpBomQuote     @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  quoteItem        SpBomQuoteItem @relation(fields: [quoteItemId], references: [id], onDelete: Cascade)

  @@unique([quoteItemId, candidateKey])
  @@index([quoteId, technicalRank])
  @@index([quoteItemId, technicalRank])
  @@map("sp_bom_quote_candidate")
}

// 자동추천은 matchEvidence에 남기고, 고객/관리자의 명시 변경만 이벤트로 누적한다.
// 안정 quoteItemId로 연결하므로 표시 순서(rowIdx)가 바뀌어도 감사 대상이 유지된다.
model SpBomQuoteSelectionEvent {
  id                   BigInt         @id @default(autoincrement())
  quoteId              BigInt
  quoteItemId          BigInt         @map("quote_item_id")
  source               String         @db.VarChar(16) // customer|catalog|admin
  actorId              String?        @db.VarChar(60)
  previousCandidateKey String?        @db.VarChar(64)
  selectedCandidateKey String?        @db.VarChar(64)
  previousMpn          String?        @db.VarChar(191)
  selectedMpn          String?        @db.VarChar(191)
  previousOfferKey     String?        @db.VarChar(64)
  selectedOfferKey     String?        @db.VarChar(64)
  previousLineTotalKrw Decimal?       @db.Decimal(14, 2)
  selectedLineTotalKrw Decimal?       @db.Decimal(14, 2)
  reasonCodes          Json?
  createdAt            DateTime       @default(now())
  quote                SpBomQuote     @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  quoteItem            SpBomQuoteItem @relation(fields: [quoteItemId], references: [id], onDelete: Cascade)

  @@index([quoteItemId, createdAt])
  @@index([quoteId, createdAt])
  @@map("sp_bom_quote_selection_event")
}
